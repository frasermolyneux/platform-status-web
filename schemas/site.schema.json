{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frasermolyneux.com/schemas/status-pages/site.schema.json",
  "title": "Site",
  "description": "Per-site configuration for a status page surface. Stored at sites/<id>/site.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "displayName", "domains", "appInsights"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,30}$",
      "description": "Stable short identifier. Used as label prefix and component-id prefix."
    },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "tagline": { "type": "string", "maxLength": 160 },
    "domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "format": "hostname" },
      "description": "Custom domains routed to this site by host-header resolution."
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "href"],
        "properties": {
          "label": { "type": "string" },
          "href": { "type": "string", "format": "uri" }
        }
      }
    },
    "appInsights": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resourceId"],
        "properties": {
          "resourceId": {
            "type": "string",
            "pattern": "^/subscriptions/[0-9a-fA-F-]{36}/resourceGroups/[^/]+/providers/Microsoft\\.Insights/components/[^/]+$"
          },
          "description": { "type": "string" }
        }
      },
      "description": "Alias → AI resource. Referenced from components.yaml via source.resource."
    },
    "incidentDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "severity": { "$ref": "#/$defs/severity" },
        "autoCloseOnAlertResolve": { "type": "boolean", "default": false }
      }
    },
    "feed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rssEnabled": { "type": "boolean", "default": true },
        "maxItems": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 }
      }
    }
  },
  "$defs": {
    "severity": { "enum": ["maintenance", "degraded", "outage"] }
  }
}
