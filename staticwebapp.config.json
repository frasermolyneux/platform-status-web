{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/assets/*", "/favicon.ico", "/*.{css,js,png,jpg,svg,ico,webp,woff,woff2}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Cache-Control": "public, max-age=300, must-revalidate"
  },
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  }
}
